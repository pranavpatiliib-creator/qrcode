# App
NODE_ENV=development
PORT=8080
NODE_PATH=./node_modules

# Database
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_SCANS_TABLE=scans

# Login
AUTH_USER_ID=safe
AUTH_PASSWORD=safe@123
AUTH_TOKEN_SECRET=change-this-secret
AUTH_TOKEN_TTL_MINUTES=720

# Scan validation
# Optional regex used to validate scanned IDs. Leave empty to accept any non-empty barcode value.
STUDENT_ID_REGEX=
# Optional strict allowlist: only these IDs can be stored (comma-separated). Leave empty to disable.
ALLOWED_STUDENT_IDS=

# CORS: comma-separated list for production, e.g. https://scanner.example.com,https://admin.example.com
ALLOWED_ORIGINS=http://localhost:8080
